double u(double x, double t)

///////////////////////////////////////////////////////////////////////////
//                                                                       //
// Here's an example of a user-defined function for the analytical soln. //
//                                                                       //
///////////////////////////////////////////////////////////////////////////

{
    double answer;

    double A = 10;
    double B = M_PI/2;
    double BSquared = B * B;
    answer = A * sin(B * x) * pow(M_E, (-BSquared * t));

    return answer;
}

void printSteady(ofstream *ptr_outputFile, ofstream *ptr_plotFile,
                 double xleft, double deltax, int N, double Usteady[], double tssnum)

///////////////////////////////////////////////////////////////////////////
//                                                                       //
// This function prints the results table and the plotting data table    //
// for the steady-state solution.  Variables in the arg list have the    //
// following meanings.                                                   //
//                                                                       //
// ptr_outputFile:        Pointer to the output file  (input)            //
// ptr_plotFile:          Pointer to the plotting data file  (input)     //
// xleft:                 x value at left end of domain  (input)         //
// deltax:                Grid spacing  (input)                          //
// N:                     One less than the number of x points (input)   //
// Usteady:               Entries 0:N are the numerical steady-state     //
//                        solution  (input)                              //
// tssnum:                t value at numerical steady state  (input)     //
//                                                                       //
///////////////////////////////////////////////////////////////////////////

{
    // Declare some variables.
    int i;
    double x;

    // Print a message to the screen.
    cout << "\n Steady-state solution is being printed"
         << " to the output file and to the plotting data file...\n\n";

    // Print the title and the column headings for the results table and for the plotting data table.
    *ptr_outputFile << fixed << setprecision(6)
                    << "\n\n       STEADY-STATE SOLN\n     AT tssnum = " << setw(9) << tssnum << "\n\n"
                    << "    i      x              U\n";
    *ptr_plotFile   << fixed << setprecision(6)
                    << "\n\n STEADY-STATE SOLN AT tssnum = " << setw(9) << tssnum << "\n\n"
                    << "          x                    U\n";

    // Print a horizontal line below the column headings.
    *ptr_outputFile << "-------------------------------\n";
    *ptr_plotFile   << "------------------------------------------\n";

    // Prepare for the loop.
    x = xleft - deltax;

    for (i=0; i<=N; i++)
    {
         x += deltax;

        // Print one row of the results table and of the plotting data table.
        *ptr_outputFile << " "  << setw(4) << i
                        << "  " << fixed << setw(8) << setprecision(5) << x
                        << "  " << setw(13) << Usteady[i] << endl;
        *ptr_plotFile   << scientific << setprecision(12)
                        << " "  << setw(19) << x
                        << "  " << setw(19) << Usteady[i] << endl;
    }

    // Print another horizontal line.
    *ptr_outputFile << "-------------------------------\n";
    *ptr_plotFile   << "------------------------------------------\n";

    return;
}
