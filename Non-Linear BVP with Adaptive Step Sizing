void evaluateGrid(int N, double dx[], double w[], double Ciip1[], double *Cequi, 
                  double *checkgrid, double epsgrid, int *NptsToAdd)

///////////////////////////////////////////////////////////////////////////
//                                                                       //
// This function evaluates the current grid in preparation for adapting  //
// the grid.  Variables in the arg list have the following meanings.     //
//                                                                       //
// N:                 One less than the size of the system  (input)      //
// dx:                Entries 0:N-1 are the grid spacings  (input)       //
// w:                 Entries 0:N are the solution vector  (input)       //
// Ciip1:             Entries 0:N-1 are the C_{i,i+1} values  (output)   //
// Cequi:             Equidistribution constant  (output)                //
// checkgrid:         Quantity that will eventually be compared to       //
//                    (1+epsgrid)*Cequi  (output)                        //
// epsgrid:           Tolerance for the adaptive gridding process (input)//
// NptsToAdd:         Number of points to be added  (output)             //
//                                                                       //
///////////////////////////////////////////////////////////////////////////

{
    // Declare some variables.
    int i;
    *Cequi = 0;
    *checkgrid = 0;
    *NptsToAdd = 0; 

    // Compute the C_{i,i+1} vector and the equidistribution constant.
    for (i = 0; i <= N-1; i++)
    {
        Ciip1[i] = sqrt(pow(dx[i], 2) + pow(w[i+1] - w[i], 2));
        *Cequi += Ciip1[i];
        if (Ciip1[i] > *checkgrid)
            *checkgrid = Ciip1[i];
    }
    *Cequi = *Cequi / N;

    // Loop through the grid to determine the number of points to be added, but don't yet add
    // those points to the grid.
    for (i = 0; i <= N - 1; i++)
    {
        if (Ciip1[i] > (1 + epsgrid) * *Cequi)
        {
            (*NptsToAdd)++;
        }

    }
    return;
}
