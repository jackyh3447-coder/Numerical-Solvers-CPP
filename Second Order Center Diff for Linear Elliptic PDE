void printPlottingData(ofstream *ptr_plotFile, double ybottom, double h, 
                       int NY, double Uconverged[NXmaxp1][NYmaxp1], 
                       double xstar, int istar)

///////////////////////////////////////////////////////////////////////////
//                                                                       //
// This function prints the plotting data table.  Variables in the arg   //
// list have the following meanings.                                     //
//                                                                       //
// ptr_plotFile:          Pointer to the plotting data file              //
// ybottom:               y value at bottom boundary                     //
// h:                     Grid spacing in x and y directions             //
// NY:                    One less than the number of y points           //
// Uconverged:            Entries [0:NX, 0:NY] are the converged         //
//                            numerical solution                         //
// xstar:                 x value at which U, u, and |e| will be output  //
// istar:                 i value corresponding to xstar                 //
//                                                                       //
// All variables in the arg list are INPUTs.                             //
//                                                                       //
///////////////////////////////////////////////////////////////////////////

{
    // Declare some variables.
    int j;
    double y;
    double uactual, error;

    // Print a message to the screen.
    cout << fixed << setprecision(4);
    cout << "\n Converged solution at x = " << setw(6) << xstar << " is being printed"
         << " to the plotting data file...\n\n";

    // Print the title and the column headings for the plotting data table.
    *ptr_plotFile   //<< fixed << setprecision(6)
                    // << " CONVERGED SOLN AT x = " << setw(9) << xstar << "\n\n"
                    << "          y                    U                    u                   |e|\n";

    // Print a horizontal line below the column headings.
    // *ptr_plotFile   << "--------------------------------------------------------------------"
    //                 << "----------------\n";

    // Prepare for the loop.
    y = ybottom - h;

    for (j=0; j<=NY; j++)
    {
         y += h;
         uactual = u(xstar, y);
         error = uactual - Uconverged[istar][j];

        // Print one row of the plotting data table.
        *ptr_plotFile   << scientific << setprecision(12)
                        << " "  << setw(19) << y
                        << "  " << setw(19) << Uconverged[istar][j]
                        << "  " << setw(19) << uactual
                        << "  " << setw(19) << fabs(error) << endl;
    }

    // Print another horizontal line.
    // *ptr_plotFile   << "--------------------------------------------------------------------"
    //                 << "----------------\n";

    return;
}
